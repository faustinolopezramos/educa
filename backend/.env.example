# development | production. With ENVIRONMENT=production the API refuses to start
# while JWT_SECRET is still the placeholder below.
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+psycopg://educa:educa@localhost:5432/educa

# JWT
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Fernet key for encrypting provider credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Shared secret used to verify inbound provider webhooks (Zoom signature /
# Google channel token). Leave empty and /webhooks/* rejects everything.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Seed admin (used by app/seed.py)
SEED_ADMIN_EMAIL=admin@educa.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Administrador
